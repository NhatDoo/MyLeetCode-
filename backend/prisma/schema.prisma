generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions Submission[]
  sessions    Session[]
  resetTokens PasswordResetToken[]
}

model Session {
  id            String   @id @default(uuid())
  userId        String

  refreshToken  String   @unique // hashed
  userAgent     String?
  ipAddress     String?

  expiresAt     DateTime
  createdAt     DateTime @default(now())

  user          User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String

  token     String   @unique // hashed
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model Problem {
  id          String   @id @default(uuid())
  title       String
  description String
  difficulty  String
  image       String?
  tags        String[] @default([])
  topics      String[] @default([])

  testcases   TestCase[]
  submissions Submission[]
}

model TestCase {
  id        String @id @default(uuid())
  input     String
  expected  String
  isHidden  Boolean @default(true)
  image     String?

  problemId String
  problem   Problem @relation(fields: [problemId], references: [id])
  logs      ExecutionLog[]
}

model Submission {
  id         String   @id @default(uuid())
  code       String
  language   String

  status     SubmissionStatus @default(PENDING)
  result     Json?
  score      Int?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  userId     String
  problemId  String

  user       User    @relation(fields: [userId], references: [id])
  problem    Problem @relation(fields: [problemId], references: [id])

  logs       ExecutionLog[]

  @@index([userId])
  @@index([problemId])
  @@index([status])
  @@index([userId, problemId])
}

model ExecutionLog {
  id           String   @id @default(uuid())
  submissionId String
  testcaseId   String

  status       String
  runtime      Int
  memory       Int?

  submission   Submission @relation(fields: [submissionId], references: [id])
  testcase     TestCase   @relation(fields: [testcaseId], references: [id])
}

enum SubmissionStatus {
  PENDING
  RUNNING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  RUNTIME_ERROR
  COMPILATION_ERROR
  SYSTEM_ERROR
}
